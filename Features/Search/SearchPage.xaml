<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="LinuxDo.Features.Search.SearchPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Padding="20,12" RowSpacing="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock Style="{StaticResource SubtitleTextBlockStyle}" Text="搜索" />

        <Grid Grid.Row="1" ColumnSpacing="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <AutoSuggestBox
                x:Name="SearchBox"
                PlaceholderText="搜索主题、帖子、用户…"
                QueryIcon="Find"
                QuerySubmitted="SearchBox_QuerySubmitted" />
            <Button Grid.Column="1" Content="筛选" Click="ToggleFilters_Click" />
            <Button Grid.Column="2" Content="搜索" Click="Search_Click" Style="{StaticResource AccentButtonStyle}" />
        </Grid>

        <Border x:Name="FiltersPanel" Grid.Row="2" Padding="12" CornerRadius="8"
                Background="{ThemeResource SubtleFillColorSecondaryBrush}" Visibility="Collapsed">
            <StackPanel Spacing="10">
                <ToggleSwitch x:Name="TitleOnlySwitch" Header="仅搜标题" OffContent="否" OnContent="是" />
                <ComboBox x:Name="CategoryBox" Header="分类" Width="280" PlaceholderText="全部分类" />
                <Grid ColumnSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="TagBox" Header="标签" PlaceholderText="例如 分享" />
                    <TextBox x:Name="UserBox" Grid.Column="1" Header="用户" PlaceholderText="用户名" />
                </Grid>
                <TextBlock FontSize="11" Opacity="0.6"
                           Text="将组合为 Discourse 搜索语法，例如 #tag @user in:title category:slug" />
            </StackPanel>
        </Border>

        <Grid Grid.Row="3">
            <ProgressRing
                x:Name="LoadingRing"
                Width="40"
                Height="40"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                IsActive="False" />
            <TextBlock
                x:Name="EmptyText"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Opacity="0.6"
                Text="输入关键词开始搜索" />
            <ListView
                x:Name="ResultList"
                IsItemClickEnabled="True"
                ItemClick="ResultList_ItemClick"
                Visibility="Collapsed">
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Padding="12,10" Spacing="4">
                            <TextBlock FontWeight="SemiBold" Text="{Binding Title}" TextWrapping="Wrap" />
                            <TextBlock FontSize="12" Opacity="0.7" Text="{Binding Subtitle}" TextWrapping="Wrap" />
                        </StackPanel>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </Grid>
    </Grid>
</Page>

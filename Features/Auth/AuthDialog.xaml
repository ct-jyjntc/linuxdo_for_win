<?xml version="1.0" encoding="utf-8" ?>
<ContentDialog
    x:Class="LinuxDo.Features.Auth.AuthDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="登录 LinuxDo"
    CloseButtonText="关闭"
    PrimaryButtonText="我已登录，立即检测"
    PrimaryButtonClick="DetectLogin_Click"
    DefaultButton="Primary"
    MinWidth="720"
    mc:Ignorable="d">

    <Grid MinHeight="480" MinWidth="640" RowSpacing="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock
            Text="LinuxDo 已禁用 User API Key，请直接在网页中登录。登录成功后会自动同步会话。"
            TextWrapping="Wrap"
            Opacity="0.75" />

        <Pivot Grid.Row="1" x:Name="ModePivot">
            <PivotItem Header="网页登录" />
            <PivotItem Header="高级" />
        </Pivot>

        <Grid Grid.Row="2" x:Name="WebPane">
            <WebView2 x:Name="LoginWebView" />
        </Grid>

        <StackPanel Grid.Row="2" x:Name="AdvancedPane" Spacing="12" Visibility="Collapsed" Padding="4">
            <TextBlock
                Text="站点管理员若重新开放 User API，可使用浏览器授权或手动 Key。LinuxDo 当前通常会提示功能已禁用。"
                TextWrapping="Wrap"
                Opacity="0.7" />
            <Button Content="浏览器 User API 授权" Click="BrowserAuth_Click" HorizontalAlignment="Left" />
            <TextBlock Text="或手动粘贴 Key：" Opacity="0.6" Margin="0,8,0,0" />
            <TextBox x:Name="ManualUsername" Header="用户名" />
            <PasswordBox x:Name="ManualKey" Header="User API Key" />
            <Button Content="使用 API Key 登录" Click="ManualLogin_Click" HorizontalAlignment="Left" />
        </StackPanel>

        <TextBlock
            Grid.Row="3"
            x:Name="StatusText"
            Text="在下方完成网站登录（支持 Connect / 密码 / 第三方）"
            Opacity="0.7"
            TextWrapping="Wrap" />
        <TextBlock
            Grid.Row="4"
            x:Name="ErrorText"
            Foreground="{ThemeResource SystemFillColorCriticalBrush}"
            TextWrapping="Wrap" />
    </Grid>
</ContentDialog>

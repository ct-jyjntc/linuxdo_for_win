<?xml version="1.0" encoding="utf-8" ?>
<ContentDialog
    x:Class="LinuxDo.Features.Auth.AuthDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="登录 LinuxDo"
    CloseButtonText="关闭"
    PrimaryButtonText="我已登录，立即检测"
    PrimaryButtonClick="DetectLogin_Click"
    DefaultButton="Primary"
    MinWidth="760"
    MaxWidth="960"
    mc:Ignorable="d">

    <!--
      WinUI ContentDialog defaults MaxWidth≈548 — must set MaxWidth on the dialog itself
      (not only content MinWidth) or the sheet stays narrow and clips CF/login UI.
    -->
    <Grid
        x:Name="RootGrid"
        MinHeight="600"
        MinWidth="700"
        RowSpacing="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" MinHeight="420" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock
            Text="使用与接口相同的浏览器上下文登录。若页面空白，点「刷新页面」。"
            TextWrapping="Wrap"
            Opacity="0.75" />

        <Pivot Grid.Row="1" x:Name="ModePivot">
            <PivotItem Header="网页登录" />
            <PivotItem Header="高级" />
        </Pivot>

        <StackPanel
            Grid.Row="2"
            x:Name="WebToolbar"
            Orientation="Horizontal"
            Spacing="8">
            <Button x:Name="RefreshPageButton" Content="刷新页面" Click="RefreshPage_Click" />
            <Button Content="打开登录页" Click="GoLogin_Click" />
            <Button Content="后退" Click="GoBack_Click" />
            <Button Content="缩小适配" Click="FitScale_Click" />
        </StackPanel>

        <Border
            Grid.Row="3"
            x:Name="WebHost"
            MinHeight="420"
            MinWidth="0"
            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
            BorderThickness="1"
            CornerRadius="4" />

        <StackPanel Grid.Row="3" x:Name="AdvancedPane" Spacing="12" Visibility="Collapsed" Padding="4">
            <TextBlock
                Text="站点管理员若重新开放 User API，可使用浏览器授权或手动 Key。LinuxDo 当前通常会提示功能已禁用。"
                TextWrapping="Wrap"
                Opacity="0.7" />
            <Button Content="浏览器 User API 授权" Click="BrowserAuth_Click" HorizontalAlignment="Left" />
            <TextBlock Text="或手动粘贴 Key：" Opacity="0.6" Margin="0,8,0,0" />
            <TextBox x:Name="ManualUsername" Header="用户名" />
            <PasswordBox x:Name="ManualKey" Header="User API Key" />
            <Button Content="使用 API Key 登录" Click="ManualLogin_Click" HorizontalAlignment="Left" />
        </StackPanel>

        <TextBlock Grid.Row="4" x:Name="StatusText" Opacity="0.8" TextWrapping="Wrap" />
        <TextBlock Grid.Row="5" x:Name="ErrorText" Foreground="DarkRed" TextWrapping="Wrap" />
    </Grid>
</ContentDialog>

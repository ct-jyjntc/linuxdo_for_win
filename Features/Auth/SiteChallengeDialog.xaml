<?xml version="1.0" encoding="utf-8" ?>
<ContentDialog
    x:Class="LinuxDo.Features.Auth.SiteChallengeDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="站点安全验证"
    PrimaryButtonText="验证完成，继续"
    SecondaryButtonText="稍后"
    PrimaryButtonClick="Complete_Click"
    SecondaryButtonClick="Dismiss_Click"
    DefaultButton="Primary"
    MinWidth="760"
    MaxWidth="960">

    <Grid MinHeight="600" MinWidth="700" RowSpacing="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" MinHeight="420" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Spacing="4">
            <TextBlock
                x:Name="MessageText"
                TextWrapping="Wrap"
                Opacity="0.85" />
            <TextBlock
                Text="验证页与接口共用同一个浏览器。若白屏，点「刷新页面」。"
                FontSize="12"
                Opacity="0.65"
                TextWrapping="Wrap" />
        </StackPanel>

        <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="8">
            <Button Content="刷新页面" Click="RefreshPage_Click" />
            <Button Content="重新打开首页" Click="ReloadHome_Click" />
            <Button Content="缩小适配" Click="FitScale_Click" />
        </StackPanel>

        <Border
            x:Name="WebHost"
            Grid.Row="2"
            MinHeight="420"
            MinWidth="0"
            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
            BorderThickness="1"
            CornerRadius="4" />

        <Grid Grid.Row="3" ColumnSpacing="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <ProgressRing
                x:Name="BusyRing"
                Width="20"
                Height="20"
                IsActive="True" />
            <TextBlock
                Grid.Column="1"
                x:Name="StatusText"
                VerticalAlignment="Center"
                Opacity="0.9"
                TextWrapping="Wrap"
                Text="正在打开验证页…" />
        </Grid>
    </Grid>
</ContentDialog>

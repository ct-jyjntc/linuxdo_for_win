<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="LinuxDo.Features.Categories.CategoriesPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Padding="20,12" RowSpacing="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <TextBlock Style="{StaticResource SubtitleTextBlockStyle}" Text="分类" />
        <Grid Grid.Row="1">
            <ProgressRing x:Name="LoadingRing" Width="40" Height="40" HorizontalAlignment="Center" VerticalAlignment="Center" IsActive="False" />
            <ListView x:Name="CategoryList" IsItemClickEnabled="True" ItemClick="CategoryList_ItemClick">
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Grid Padding="12,10" ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Border Width="12" Height="12" CornerRadius="3" Background="{Binding ColorBrush}" VerticalAlignment="Center" />
                            <StackPanel Grid.Column="1" Spacing="2">
                                <TextBlock FontWeight="SemiBold" Text="{Binding Name}" />
                                <TextBlock FontSize="12" Opacity="0.6" Text="{Binding Description}" TextTrimming="CharacterEllipsis" MaxLines="1" />
                            </StackPanel>
                            <TextBlock Grid.Column="2" VerticalAlignment="Center" FontSize="12" Opacity="0.5" Text="{Binding CountText}" />
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
            <TextBlock x:Name="EmptyText" HorizontalAlignment="Center" VerticalAlignment="Center" Opacity="0.6" Visibility="Collapsed" Text="暂无分类" />
        </Grid>
    </Grid>
</Page>

<?xml version="1.0" encoding="utf-8" ?>
<UserControl
    x:Class="LinuxDo.Features.Topic.UserHoverCardControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:LinuxDo.Controls">

    <Border Width="300" Padding="14" CornerRadius="8"
            Background="{ThemeResource AcrylicBackgroundFillColorDefaultBrush}"
            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
        <StackPanel Spacing="10">
            <ProgressRing x:Name="LoadingRing" Width="24" Height="24" IsActive="True" HorizontalAlignment="Left" />
            <TextBlock x:Name="ErrorText" FontSize="12" Opacity="0.7" TextWrapping="Wrap" Visibility="Collapsed" />
            <Grid x:Name="CardBody" ColumnSpacing="12" Visibility="Collapsed">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Border Width="56" Height="56" CornerRadius="28" Background="{ThemeResource SubtleFillColorSecondaryBrush}">
                    <controls:CachedImage x:Name="AvatarImage" Width="56" Height="56" Stretch="UniformToFill" />
                </Border>
                <StackPanel Grid.Column="1" Spacing="2">
                    <TextBlock x:Name="DisplayNameText" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                    <TextBlock x:Name="UsernameText" FontSize="12" Opacity="0.7" />
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <Border x:Name="TlBadge" Padding="6,2" CornerRadius="8" Background="{ThemeResource AccentFillColorDefaultBrush}" Opacity="0.2">
                            <TextBlock x:Name="TlText" FontSize="11" FontWeight="SemiBold" />
                        </Border>
                        <TextBlock x:Name="TitleText" FontSize="11" Opacity="0.65" TextTrimming="CharacterEllipsis" />
                    </StackPanel>
                </StackPanel>
            </Grid>
            <TextBlock x:Name="BioText" FontSize="12" Opacity="0.75" TextWrapping="Wrap" MaxLines="4" TextTrimming="CharacterEllipsis" />
            <StackPanel x:Name="StatsPanel" Orientation="Horizontal" Spacing="14" Visibility="Collapsed">
                <StackPanel>
                    <TextBlock x:Name="FollowersText" FontWeight="SemiBold" />
                    <TextBlock FontSize="11" Opacity="0.6" Text="粉丝" />
                </StackPanel>
                <StackPanel>
                    <TextBlock x:Name="FollowingText" FontWeight="SemiBold" />
                    <TextBlock FontSize="11" Opacity="0.6" Text="关注" />
                </StackPanel>
                <StackPanel>
                    <TextBlock x:Name="BadgesText" FontWeight="SemiBold" />
                    <TextBlock FontSize="11" Opacity="0.6" Text="徽章" />
                </StackPanel>
            </StackPanel>
            <StackPanel Orientation="Horizontal" Spacing="8">
                <Button x:Name="ProfileButton" Content="查看主页" Click="Profile_Click" Style="{StaticResource AccentButtonStyle}" />
                <Button x:Name="MessageButton" Content="私信" Click="Message_Click" />
            </StackPanel>
        </StackPanel>
    </Border>
</UserControl>

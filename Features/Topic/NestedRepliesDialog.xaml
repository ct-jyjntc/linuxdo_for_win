<?xml version="1.0" encoding="utf-8" ?>
<ContentDialog
    x:Class="LinuxDo.Features.Topic.NestedRepliesDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="嵌套回复"
    CloseButtonText="关闭"
    PrimaryButtonText="刷新"
    PrimaryButtonClick="Refresh_Click"
    MinWidth="560">

    <Grid MinHeight="480" MinWidth="520">
        <ProgressRing x:Name="LoadingRing" Width="40" Height="40" HorizontalAlignment="Center" VerticalAlignment="Center" />
        <TextBlock x:Name="EmptyText" HorizontalAlignment="Center" VerticalAlignment="Center" Opacity="0.7"
                   Text="暂无嵌套数据（站点可能未启用）" Visibility="Collapsed" TextWrapping="Wrap" MaxWidth="360" />
        <ListView x:Name="ReplyList" SelectionMode="None" IsItemClickEnabled="True" ItemClick="ReplyList_ItemClick">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Grid Padding="8,6" ColumnSpacing="8" Margin="{Binding Indent}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Button Content="{Binding ExpandGlyph}" Click="Expand_Click" Tag="{Binding}"
                                Width="32" Style="{StaticResource SubtleButtonStyle}"
                                Visibility="{Binding ShowExpand}" />
                        <StackPanel Grid.Column="1" Spacing="2">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBlock FontWeight="SemiBold" Text="{Binding Author}" />
                                <TextBlock FontSize="11" Opacity="0.5" Text="{Binding FloorLabel}" />
                            </StackPanel>
                            <TextBlock Text="{Binding Excerpt}" TextWrapping="Wrap" MaxLines="3"
                                       TextTrimming="CharacterEllipsis" Opacity="0.85" />
                        </StackPanel>
                        <TextBlock Grid.Column="2" VerticalAlignment="Center" FontSize="11" Opacity="0.5"
                                   Text="{Binding ReplyCountText}" />
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</ContentDialog>

<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="LinuxDo.Features.Topic.TopicDetailPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:LinuxDo.Features.Topic"
    xmlns:controls="using:LinuxDo.Controls">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Padding="20,12,20,8" Spacing="8">
            <TextBlock
                Style="{StaticResource SubtitleTextBlockStyle}"
                Text="{x:Bind ViewModel.Title, Mode=OneWay}"
                TextWrapping="WrapWholeWords" />
            <StackPanel Orientation="Horizontal" Spacing="8">
                <TextBlock FontSize="12" Opacity="0.7" Text="{x:Bind ViewModel.PageLabel, Mode=OneWay}" />
                <TextBlock FontSize="12" Opacity="0.5" Text="·" />
                <TextBlock FontSize="12" Opacity="0.7">
                    <Run Text="👁 " /><Run Text="{x:Bind ViewModel.Views, Mode=OneWay}" />
                    <Run Text="  ❤ " /><Run Text="{x:Bind ViewModel.LikeCount, Mode=OneWay}" />
                    <Run Text="  💬 " /><Run Text="{x:Bind ViewModel.ReplyCount, Mode=OneWay}" />
                </TextBlock>
            </StackPanel>
            <CommandBar DefaultLabelPosition="Right" Background="Transparent">
                <AppBarButton Icon="Refresh" Label="刷新" Click="Refresh_Click" />
                <AppBarButton Icon="Favorite" Label="书签" Click="BookmarkTopic_Click" />
                <AppBarButton Icon="Share" Label="复制链接" Click="Share_Click" />
                <AppBarButton Icon="ReShare" Label="系统分享" Click="SystemShare_Click" />
                <AppBarButton Icon="Copy" Label="导出 MD" Click="ExportMd_Click" />
                <AppBarButton Icon="Pictures" Label="分享长图" Click="ShareImage_Click" />
                <AppBarButton Icon="MailReply" Label="回复" Click="Reply_Click" />
                <AppBarButton Icon="Flag" Label="俺也一样" Click="SharedIssue_Click" />
                <AppBarButton Icon="ShowResults" Label="嵌套回复" Click="NestedReplies_Click" />
                <CommandBar.SecondaryCommands>
                    <AppBarButton Label="在新窗口打开" Click="OpenNewWindow_Click" />
                    <AppBarButton Label="静音" Click="NotifyMuted_Click" />
                    <AppBarButton Label="正常" Click="NotifyRegular_Click" />
                    <AppBarButton Label="跟踪" Click="NotifyTracking_Click" />
                    <AppBarButton Label="监视" Click="NotifyWatching_Click" />
                    <AppBarSeparator />
                    <AppBarButton Label="关闭/打开主题" Click="CloseTopic_Click" />
                    <AppBarButton Label="置顶" Click="PinTopic_Click" />
                    <AppBarButton Label="归档" Click="ArchiveTopic_Click" />
                    <AppBarButton Label="在浏览器打开" Click="OpenBrowser_Click" />
                    <AppBarButton Label="稍后阅读" Click="ReadLater_Click" />
                </CommandBar.SecondaryCommands>
            </CommandBar>
            <InfoBar
                IsOpen="{x:Bind ViewModel.ActionMessage, Mode=OneWay, Converter={StaticResource StringToBoolConverter}}"
                Message="{x:Bind ViewModel.ActionMessage, Mode=OneWay}"
                Severity="Informational"
                IsClosable="True" />
            <InfoBar
                x:Name="NewRepliesBar"
                Title="有新回复"
                Message="{x:Bind ViewModel.ActionMessage, Mode=OneWay}"
                Severity="Success"
                IsOpen="False"
                IsClosable="True">
                <InfoBar.ActionButton>
                    <Button Content="查看最新" Click="LoadNewReplies_Click" />
                </InfoBar.ActionButton>
            </InfoBar>
        </StackPanel>

        <Grid Grid.Row="1">
            <ProgressRing
                Width="40" Height="40"
                HorizontalAlignment="Center" VerticalAlignment="Center"
                IsActive="{x:Bind ViewModel.IsLoading, Mode=OneWay}" />
            <StackPanel x:Name="ErrorPanel" HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="12" Visibility="Collapsed">
                <FontIcon FontSize="32" Glyph="&#xE783;" />
                <TextBlock x:Name="ErrorText" MaxWidth="420" TextWrapping="Wrap" />
                <Button Content="重试" Click="Refresh_Click" HorizontalAlignment="Center" />
            </StackPanel>

            <ListView x:Name="PostList" ItemsSource="{x:Bind ViewModel.Posts, Mode=OneWay}" SelectionMode="None" Padding="8,0">
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="local:PostItemViewModel">
                        <Border Margin="8,6" Padding="14" CornerRadius="8"
                                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                            <StackPanel Spacing="10">
                                <Grid ColumnSpacing="10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <Button Background="Transparent" BorderThickness="0" Padding="0"
                                            Click="Avatar_Click" Tag="{x:Bind}"
                                            PointerEntered="Avatar_PointerEntered"
                                            PointerExited="Avatar_PointerExited"
                                            ToolTipService.ToolTip="{x:Bind AuthorName, Mode=OneWay}">
                                        <Border Width="40" Height="40" CornerRadius="20" Background="{ThemeResource SubtleFillColorSecondaryBrush}">
                                            <controls:CachedImage
                                                Width="40" Height="40"
                                                SourceUrl="{x:Bind AvatarUrl, Mode=OneWay}"
                                                Stretch="UniformToFill" />
                                        </Border>
                                    </Button>
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <HyperlinkButton Content="{x:Bind AuthorName, Mode=OneWay}" Click="Author_Click" Tag="{x:Bind}" Padding="0" />
                                            <TextBlock FontSize="12" Opacity="0.6" Text="{x:Bind UserTitle, Mode=OneWay}" VerticalAlignment="Center" />
                                            <FontIcon FontSize="11" Glyph="&#xEA18;" Visibility="{x:Bind IsStaff, Mode=OneWay}" />
                                        </StackPanel>
                                        <TextBlock FontSize="11" Opacity="0.5" Text="{x:Bind TimeText, Mode=OneWay}" />
                                    </StackPanel>
                                    <TextBlock Grid.Column="2" VerticalAlignment="Center" FontSize="12" Opacity="0.5" Text="{x:Bind FloorLabel, Mode=OneWay}" />
                                </Grid>

                                <Border Background="#1A107C10" Padding="8,4" CornerRadius="4" Visibility="{x:Bind IsAccepted, Mode=OneWay}">
                                    <TextBlock Text="✓ 已采纳答案" FontSize="12" FontWeight="SemiBold" Foreground="#FF107C10" />
                                </Border>
                                <Border Background="{ThemeResource SubtleFillColorSecondaryBrush}" Padding="8,4" CornerRadius="4" Visibility="{x:Bind IsDeleted, Mode=OneWay}">
                                    <TextBlock Text="此帖已删除" FontSize="12" Opacity="0.7" />
                                </Border>

                                <ItemsControl ItemsSource="{x:Bind Blocks, Mode=OneWay}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="local:ContentBlockVm">
                                            <StackPanel Margin="0,2" Spacing="4">
                                                <controls:InlineTextBlock
                                                    Text="{x:Bind Text, Mode=OneWay}"
                                                    Html="{x:Bind HtmlSource, Mode=OneWay}"
                                                    Spans="{x:Bind InlineSpans, Mode=OneWay}"
                                                    ContentFontSize="{x:Bind FontSize}"
                                                    ContentLineHeight="{x:Bind LineHeight}"
                                                    Visibility="{x:Bind ShowPlainText, Mode=OneWay}" />
                                                <StackPanel Visibility="{x:Bind IsCollapsed, Mode=OneWay}">
                                                    <TextBlock Text="{x:Bind CollapsedPreview, Mode=OneWay}" TextWrapping="WrapWholeWords"
                                                               FontSize="{x:Bind FontSize}" Opacity="0.85" />
                                                    <HyperlinkButton Content="展开全文…" Click="ExpandBlock_Click" Tag="{x:Bind}" Padding="0"
                                                                     Visibility="{x:Bind ShowExpandButton, Mode=OneWay}" />
                                                </StackPanel>
                                                <HyperlinkButton Content="收起" Click="CollapseBlock_Click" Tag="{x:Bind}" Padding="0"
                                                                 Visibility="{x:Bind ShowCollapseButton, Mode=OneWay}" />
                                                <Border Margin="0,4" Padding="10,8" CornerRadius="6"
                                                        Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                                                        BorderBrush="{ThemeResource AccentFillColorDefaultBrush}" BorderThickness="3,0,0,0"
                                                        Visibility="{x:Bind IsQuote}">
                                                    <StackPanel>
                                                        <TextBlock FontSize="11" Opacity="0.6" Text="{x:Bind QuoteAuthor}" />
                                                        <controls:InlineTextBlock
                                                            Text="{x:Bind Text}"
                                                            Spans="{x:Bind InlineSpans, Mode=OneWay}"
                                                            ContentFontSize="{x:Bind FontSize}"
                                                            ContentLineHeight="{x:Bind LineHeight}" />
                                                    </StackPanel>
                                                </Border>
                                                <Border Margin="0,4" Padding="10" CornerRadius="6"
                                                        Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                                                        Visibility="{x:Bind IsCode}">
                                                    <TextBlock Text="{x:Bind Text}" FontFamily="Consolas" FontSize="12"
                                                               TextWrapping="Wrap" IsTextSelectionEnabled="True" />
                                                </Border>
                                                <Button Margin="0,6" Padding="0" Background="Transparent" BorderThickness="0"
                                                        Click="Image_Click" Tag="{x:Bind ImageUrl}" Visibility="{x:Bind IsImage}">
                                                    <controls:CachedImage
                                                        SourceUrl="{x:Bind ImageUrl}"
                                                        MaxHeight="360"
                                                        MinHeight="80"
                                                        MinWidth="120"
                                                        Stretch="Uniform"
                                                        HorizontalAlignment="Left" />
                                                </Button>
                                                <Border Margin="0,6" Padding="10" CornerRadius="8"
                                                        Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                                                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                                        BorderThickness="1"
                                                        Visibility="{x:Bind IsLink}">
                                                    <HyperlinkButton NavigateUri="{x:Bind LinkUrl}" Padding="0" HorizontalAlignment="Stretch">
                                                        <Grid ColumnSpacing="12">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="Auto" />
                                                                <ColumnDefinition Width="*" />
                                                            </Grid.ColumnDefinitions>
                                                            <controls:CachedImage
                                                                SourceUrl="{x:Bind LinkImageUrl, Mode=OneWay}"
                                                                Width="72" Height="72"
                                                                Stretch="UniformToFill"
                                                                Visibility="{x:Bind HasLinkImage, Mode=OneWay}" />
                                                            <Border Width="72" Height="72" CornerRadius="6"
                                                                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                                                    Visibility="{x:Bind HasLinkImage, Mode=OneWay, Converter={StaticResource InvertBoolConverter}}">
                                                                <FontIcon Glyph="&#xE71B;" HorizontalAlignment="Center" VerticalAlignment="Center" Opacity="0.5" />
                                                            </Border>
                                                            <StackPanel Grid.Column="1" Spacing="2">
                                                                <TextBlock FontSize="11" Opacity="0.6" Text="{x:Bind QuoteAuthor, Mode=OneWay}" />
                                                                <TextBlock FontWeight="SemiBold" TextWrapping="Wrap" MaxLines="2"
                                                                           Text="{x:Bind Text, Mode=OneWay}" />
                                                                <TextBlock FontSize="12" Opacity="0.7" TextWrapping="Wrap" MaxLines="2"
                                                                           Text="{x:Bind LinkExcerpt, Mode=OneWay}" />
                                                                <ProgressRing Width="16" Height="16" IsActive="{x:Bind IsLinkLoading, Mode=OneWay}"
                                                                              Visibility="{x:Bind IsLinkLoading, Mode=OneWay}" />
                                                            </StackPanel>
                                                        </Grid>
                                                    </HyperlinkButton>
                                                </Border>
                                                <Border Margin="0,4" Padding="10,8" CornerRadius="6"
                                                        Background="{ThemeResource SubtleFillColorTertiaryBrush}"
                                                        Visibility="{x:Bind IsSpoiler}">
                                                    <StackPanel>
                                                        <TextBlock FontSize="11" Opacity="0.6" Text="剧透" />
                                                        <TextBlock Text="{x:Bind Text}" TextWrapping="Wrap" IsTextSelectionEnabled="True" />
                                                    </StackPanel>
                                                </Border>
                                                <Border Margin="0,6" Padding="0" CornerRadius="6"
                                                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                                        BorderThickness="1"
                                                        Visibility="{x:Bind IsTable}">
                                                    <ScrollViewer HorizontalScrollMode="Enabled" HorizontalScrollBarVisibility="Auto"
                                                                  VerticalScrollMode="Disabled">
                                                        <ItemsControl ItemsSource="{x:Bind TableRows}">
                                                            <ItemsControl.ItemTemplate>
                                                                <DataTemplate x:DataType="local:TableRowVm">
                                                                    <Border BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                                                                            BorderThickness="0,0,0,1"
                                                                            Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                                                                            Padding="0">
                                                                        <ItemsControl ItemsSource="{x:Bind Cells}">
                                                                            <ItemsControl.ItemsPanel>
                                                                                <ItemsPanelTemplate>
                                                                                    <StackPanel Orientation="Horizontal" />
                                                                                </ItemsPanelTemplate>
                                                                            </ItemsControl.ItemsPanel>
                                                                            <ItemsControl.ItemTemplate>
                                                                                <DataTemplate x:DataType="local:TableCellVm">
                                                                                    <Border MinWidth="80" MaxWidth="220" Padding="10,6"
                                                                                            BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                                                                                            BorderThickness="0,0,1,0">
                                                                                        <TextBlock Text="{x:Bind Text}" TextWrapping="Wrap"
                                                                                                   FontWeight="SemiBold"
                                                                                                   IsTextSelectionEnabled="True"
                                                                                                   FontSize="12" />
                                                                                    </Border>
                                                                                </DataTemplate>
                                                                            </ItemsControl.ItemTemplate>
                                                                        </ItemsControl>
                                                                    </Border>
                                                                </DataTemplate>
                                                            </ItemsControl.ItemTemplate>
                                                        </ItemsControl>
                                                    </ScrollViewer>
                                                </Border>
                                                <Border Height="1" Margin="0,8" Background="{ThemeResource DividerStrokeColorDefaultBrush}" Visibility="{x:Bind IsHr}" />
                                            </StackPanel>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <ItemsControl ItemsSource="{x:Bind Polls, Mode=OneWay}" Visibility="{x:Bind HasPolls, Mode=OneWay}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="local:PollVm">
                                            <Border Margin="0,6" Padding="12" CornerRadius="8"
                                                    Background="{ThemeResource SubtleFillColorSecondaryBrush}">
                                                <StackPanel Spacing="8">
                                                    <TextBlock FontSize="12" FontWeight="SemiBold" Opacity="0.75">
                                                        <Run Text="投票 · " /><Run Text="{x:Bind Voters, Mode=OneWay}" /><Run Text=" 人参与" />
                                                    </TextBlock>
                                                    <ItemsControl ItemsSource="{x:Bind Options}">
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate x:DataType="local:PollOptionVm">
                                                                <Button Margin="0,2" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                                                                        Click="PollOption_Click" Tag="{x:Bind}">
                                                                    <StackPanel Spacing="4" Width="360">
                                                                        <Grid>
                                                                            <TextBlock Text="{x:Bind Label}" TextWrapping="Wrap" />
                                                                            <TextBlock HorizontalAlignment="Right" FontSize="11" Opacity="0.6" Text="{x:Bind Votes, Mode=OneWay}" />
                                                                        </Grid>
                                                                        <ProgressBar Maximum="1" Value="{x:Bind Fraction, Mode=OneWay}" Height="6" />
                                                                    </StackPanel>
                                                                </Button>
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <ItemsControl ItemsSource="{x:Bind ReactionChips, Mode=OneWay}" Visibility="{x:Bind HasReactions, Mode=OneWay}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <StackPanel Orientation="Horizontal" Spacing="6" />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Padding="8,2" CornerRadius="10" Background="{ThemeResource SubtleFillColorTertiaryBrush}">
                                                <TextBlock FontSize="12" Text="{Binding}" />
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <ItemsControl ItemsSource="{x:Bind Boosts, Mode=OneWay}" Visibility="{x:Bind HasBoosts, Mode=OneWay}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="local:BoostItemVm">
                                            <Border Margin="0,4" Padding="10" CornerRadius="6" Background="#22FF8C00">
                                                <Grid ColumnSpacing="8">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto" />
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Text="⚡" VerticalAlignment="Top" />
                                                    <StackPanel Grid.Column="1" Spacing="2">
                                                        <TextBlock FontSize="11" FontWeight="SemiBold" Opacity="0.75" Text="{x:Bind Author}" />
                                                        <TextBlock FontSize="12" Text="{x:Bind Body}" TextWrapping="Wrap" />
                                                    </StackPanel>
                                                    <Button Grid.Column="2" Content="删除" FontSize="11"
                                                            Click="DeleteBoost_Click" Tag="{x:Bind}"
                                                            Visibility="{x:Bind CanDelete}"
                                                            Style="{StaticResource SubtleButtonStyle}" />
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <StackPanel Orientation="Horizontal" Spacing="4">
                                    <Button Content="{x:Bind LikeLabel, Mode=OneWay}" Click="Like_Click" Tag="{x:Bind}" Style="{StaticResource SubtleButtonStyle}" />
                                    <Button Content="回复" Click="ReplyPost_Click" Tag="{x:Bind}" Style="{StaticResource SubtleButtonStyle}" />
                                    <Button Content="书签" Click="BookmarkPost_Click" Tag="{x:Bind}" Style="{StaticResource SubtleButtonStyle}" />
                                    <Button Content="👍" Click="React_Click" Tag="+1" Style="{StaticResource SubtleButtonStyle}" />
                                    <Button Content="❤️" Click="React_Click" Tag="heart" Style="{StaticResource SubtleButtonStyle}" />
                                    <Button Content="😄" Click="React_Click" Tag="laughing" Style="{StaticResource SubtleButtonStyle}" />
                                    <Button Content="🎉" Click="React_Click" Tag="confetti_ball" Style="{StaticResource SubtleButtonStyle}" />
                                    <Button Content="反应" Click="ReactionUsers_Click" Tag="{x:Bind}" Style="{StaticResource SubtleButtonStyle}" />
                                    <Button Content="Boost" Click="Boost_Click" Tag="{x:Bind}" Style="{StaticResource SubtleButtonStyle}" />
                                    <Button Content="编辑" Click="Edit_Click" Tag="{x:Bind}" Visibility="{x:Bind CanEdit, Mode=OneWay}" Style="{StaticResource SubtleButtonStyle}" />
                                    <Button Content="删除" Click="Delete_Click" Tag="{x:Bind}" Visibility="{x:Bind CanDelete, Mode=OneWay}" Style="{StaticResource SubtleButtonStyle}" />
                                    <Button Content="恢复" Click="Recover_Click" Tag="{x:Bind}" Visibility="{x:Bind CanRecover, Mode=OneWay}" Style="{StaticResource SubtleButtonStyle}" />
                                    <Button Content="采纳" Click="Accept_Click" Tag="{x:Bind}" Visibility="{x:Bind CanAccept, Mode=OneWay}" Style="{StaticResource SubtleButtonStyle}" />
                                    <Button Content="举报" Click="Flag_Click" Tag="{x:Bind}" Style="{StaticResource SubtleButtonStyle}" />
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </Grid>

        <Border Grid.Row="2" Padding="16,10"
                BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}" BorderThickness="0,1,0,0"
                Background="{ThemeResource LayerFillColorDefaultBrush}">
            <Grid ColumnSpacing="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="80" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Button Content="上一页" Click="PrevPage_Click" IsEnabled="{x:Bind ViewModel.CanGoPreviousPage, Mode=OneWay}" />
                <TextBlock Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Center"
                           Text="{x:Bind ViewModel.PageLabel, Mode=OneWay}" />
                <Button Grid.Column="2" Content="下一页" Click="NextPage_Click" IsEnabled="{x:Bind ViewModel.CanGoNextPage, Mode=OneWay}" />
                <TextBlock Grid.Column="3" VerticalAlignment="Center" Text="跳楼" Opacity="0.7" />
                <TextBox Grid.Column="4" x:Name="JumpBox" PlaceholderText="#" />
                <Button Grid.Column="5" Content="Go" Click="Jump_Click" />
            </Grid>
        </Border>
    </Grid>
</Page>

<?xml version="1.0" encoding="utf-8" ?>
<ContentDialog
    x:Class="LinuxDo.Features.Topic.ReactionUsersDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="反应用户"
    CloseButtonText="关闭"
    MinWidth="420">

    <Grid MinHeight="360" MinWidth="380" RowSpacing="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <ScrollViewer HorizontalScrollMode="Enabled" HorizontalScrollBarVisibility="Auto" VerticalScrollMode="Disabled">
            <StackPanel x:Name="ChipPanel" Orientation="Horizontal" Spacing="8" />
        </ScrollViewer>
        <ListView x:Name="UserList" Grid.Row="1" IsItemClickEnabled="True" ItemClick="UserList_ItemClick">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <StackPanel Orientation="Horizontal" Spacing="10" Padding="4">
                        <Border Width="32" Height="32" CornerRadius="16" Background="{ThemeResource SubtleFillColorSecondaryBrush}">
                            <Image Width="32" Height="32" Stretch="UniformToFill" Source="{Binding Avatar}" />
                        </Border>
                        <StackPanel>
                            <TextBlock FontWeight="SemiBold" Text="{Binding DisplayName}" />
                            <TextBlock FontSize="11" Opacity="0.65" Text="{Binding Username}" />
                        </StackPanel>
                    </StackPanel>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
        <ProgressRing x:Name="LoadingRing" Grid.RowSpan="2" Width="36" Height="36" HorizontalAlignment="Center" VerticalAlignment="Center" />
        <TextBlock x:Name="EmptyText" Grid.Row="1" HorizontalAlignment="Center" VerticalAlignment="Center" Opacity="0.65" Visibility="Collapsed" />
    </Grid>
</ContentDialog>

<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="LinuxDo.Features.Connect.TrustLevelPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ScrollViewer>
        <StackPanel Padding="24,16" Spacing="14" MaxWidth="820" HorizontalAlignment="Left">
            <Grid>
                <TextBlock x:Name="TitleText" Style="{StaticResource SubtitleTextBlockStyle}" Text="信任等级" />
                <Button HorizontalAlignment="Right" Content="网页版" Click="OpenWeb_Click" />
            </Grid>

            <ProgressRing x:Name="LoadingRing" Width="40" Height="40" HorizontalAlignment="Center" />
            <TextBlock x:Name="ErrorText" Foreground="{ThemeResource SystemFillColorCriticalBrush}" TextWrapping="Wrap" />

            <Border x:Name="CardPanel" Padding="16" CornerRadius="10"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1"
                    Visibility="Collapsed">
                <StackPanel Spacing="12">
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <TextBlock x:Name="CardTitle" FontSize="20" FontWeight="Bold" />
                        <Border x:Name="BadgeBorder" Padding="8,2" CornerRadius="8">
                            <TextBlock x:Name="BadgeText" FontSize="12" FontWeight="SemiBold" />
                        </Border>
                    </StackPanel>
                    <TextBlock x:Name="SubtitleText" Opacity="0.75" TextWrapping="Wrap" />
                    <TextBlock x:Name="StatusText" FontWeight="SemiBold" />

                    <TextBlock Style="{StaticResource BodyStrongTextBlockStyle}" Text="进度环" />
                    <ItemsControl x:Name="RingsList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,4" ColumnSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="140" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{Binding Label}" VerticalAlignment="Center" />
                                    <ProgressBar Grid.Column="1" Maximum="1" Value="{Binding Progress}" Height="10" />
                                    <TextBlock Grid.Column="2" Text="{Binding ValueText}" FontSize="12" Opacity="0.7" />
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <TextBlock Style="{StaticResource BodyStrongTextBlockStyle}" Text="进度条" />
                    <ItemsControl x:Name="BarsList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,4" ColumnSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="140" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{Binding Label}" VerticalAlignment="Center" />
                                    <ProgressBar Grid.Column="1" Maximum="1" Value="{Binding Progress}" Height="10" />
                                    <TextBlock Grid.Column="2" Text="{Binding CurrentText}" FontSize="12" Opacity="0.7" />
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <TextBlock Style="{StaticResource BodyStrongTextBlockStyle}" Text="配额" />
                    <ItemsControl x:Name="QuotasList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Margin="0,4" Spacing="2">
                                    <TextBlock>
                                        <Run Text="{Binding Label}" FontWeight="SemiBold" />
                                        <Run Text="  " />
                                        <Run Text="{Binding ValueText}" />
                                    </TextBlock>
                                    <TextBlock FontSize="11" Opacity="0.65">
                                        <Run Text="槽位 " /><Run Text="{Binding UsedSlots}" /><Run Text="/" /><Run Text="{Binding TotalSlots}" />
                                    </TextBlock>
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <TextBlock Style="{StaticResource BodyStrongTextBlockStyle}" Text="否决项" />
                    <ItemsControl x:Name="VetosList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="0,4" Padding="10" CornerRadius="6"
                                        Background="{ThemeResource SubtleFillColorSecondaryBrush}">
                                    <StackPanel Spacing="2">
                                        <TextBlock FontWeight="SemiBold" Text="{Binding Label}" />
                                        <TextBlock FontSize="12" Opacity="0.75" Text="{Binding Desc}" TextWrapping="Wrap" />
                                        <TextBlock FontSize="12" Text="{Binding Value}" />
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <TextBlock x:Name="FooterHint" FontSize="12" Opacity="0.65" TextWrapping="Wrap" />
                </StackPanel>
            </Border>

            <TextBlock Opacity="0.65" TextWrapping="Wrap"
                       Text="数据来自 connect.linux.do 页面解析。若结构变更可使用「网页版」查看。" />
        </StackPanel>
    </ScrollViewer>
</Page>

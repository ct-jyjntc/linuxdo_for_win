<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="LinuxDo.Features.Tags.TagTopicsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:home="using:LinuxDo.Features.Home">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <Grid Padding="20,12">
            <TextBlock x:Name="TitleText" Style="{StaticResource SubtitleTextBlockStyle}" />
        </Grid>
        <Grid Grid.Row="1">
            <ProgressRing x:Name="LoadingRing" Width="40" Height="40" HorizontalAlignment="Center" VerticalAlignment="Center" IsActive="False" Visibility="Collapsed" />
            <ListView x:Name="TopicList" IsItemClickEnabled="True" ItemClick="TopicList_ItemClick"
                      ContainerContentChanging="TopicList_ContainerContentChanging">
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="home:TopicListItemViewModel">
                        <StackPanel Padding="16,10" Spacing="4">
                            <TextBlock FontWeight="SemiBold" Text="{x:Bind DisplayTitle, Mode=OneWay}" TextWrapping="Wrap" MaxLines="2" />
                            <TextBlock FontSize="12" Opacity="0.6" Text="{x:Bind Meta, Mode=OneWay}" />
                        </StackPanel>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </Grid>
    </Grid>
</Page>

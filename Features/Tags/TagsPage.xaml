<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="LinuxDo.Features.Tags.TagsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Padding="20,12" RowSpacing="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <TextBlock Style="{StaticResource SubtitleTextBlockStyle}" Text="标签" />
        <Grid Grid.Row="1">
            <GridView
                x:Name="TagGrid"
                IsItemClickEnabled="True"
                ItemClick="TagGrid_ItemClick"
                SelectionMode="None">
                <GridView.ItemTemplate>
                    <DataTemplate>
                        <Border
                            Margin="4"
                            Padding="12,8"
                            MinWidth="100"
                            CornerRadius="8"
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1">
                            <StackPanel Spacing="2">
                                <TextBlock FontWeight="SemiBold" Text="{Binding Name}" />
                                <TextBlock FontSize="11" Opacity="0.6" Text="{Binding CountText}" />
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </GridView.ItemTemplate>
            </GridView>
            <ProgressRing x:Name="LoadingRing" Width="40" Height="40" HorizontalAlignment="Center" VerticalAlignment="Center" IsActive="False" />
            <TextBlock x:Name="EmptyText" HorizontalAlignment="Center" VerticalAlignment="Center" Opacity="0.6" Visibility="Collapsed" Text="暂无标签" />
        </Grid>
    </Grid>
</Page>

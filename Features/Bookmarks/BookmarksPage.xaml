<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="LinuxDo.Features.Bookmarks.BookmarksPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Padding="20,12" RowSpacing="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <Grid>
            <TextBlock Style="{StaticResource SubtitleTextBlockStyle}" Text="书签" />
        </Grid>
        <Grid Grid.Row="1">
            <ProgressRing x:Name="LoadingRing" Width="40" Height="40" HorizontalAlignment="Center" VerticalAlignment="Center" IsActive="False" Visibility="Collapsed" />
            <ListView x:Name="BookmarkList" IsItemClickEnabled="True" ItemClick="BookmarkList_ItemClick">
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Grid Padding="12,10" ColumnSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Spacing="4">
                                <TextBlock FontWeight="SemiBold" Text="{Binding Title}" TextWrapping="Wrap" />
                                <TextBlock FontSize="12" Opacity="0.65" Text="{Binding Subtitle}" TextWrapping="Wrap" />
                                <TextBlock FontSize="11" Opacity="0.5" Text="{Binding ReminderText}" />
                            </StackPanel>
                            <Button Grid.Column="1" Content="编辑" Click="Edit_Click" Tag="{Binding}" VerticalAlignment="Center" Style="{StaticResource SubtleButtonStyle}" />
                            <Button Grid.Column="2" Content="删除" Click="Delete_Click" Tag="{Binding}" VerticalAlignment="Center" Style="{StaticResource SubtleButtonStyle}" />
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
            <TextBlock x:Name="EmptyText" HorizontalAlignment="Center" VerticalAlignment="Center" Opacity="0.6" Text="暂无书签" Visibility="Collapsed" />
        </Grid>
    </Grid>
</Page>

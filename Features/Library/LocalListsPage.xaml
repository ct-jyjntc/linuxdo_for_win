<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="LinuxDo.Features.Library.LocalListsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Padding="20,12" RowSpacing="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <Grid>
            <TextBlock x:Name="TitleText" Style="{StaticResource SubtitleTextBlockStyle}" />
            <StackPanel HorizontalAlignment="Right" Orientation="Horizontal" Spacing="8">
                <Button Content="清空" Click="Clear_Click" />
            </StackPanel>
        </Grid>
        <ListView x:Name="ItemList" Grid.Row="1" IsItemClickEnabled="True" ItemClick="ItemList_ItemClick">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <StackPanel Padding="12,10" Spacing="4">
                        <TextBlock FontWeight="SemiBold" Text="{Binding Title}" TextWrapping="Wrap" />
                        <TextBlock FontSize="12" Opacity="0.65" Text="{Binding Subtitle}" />
                    </StackPanel>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
        <TextBlock x:Name="EmptyText" Grid.Row="1" HorizontalAlignment="Center" VerticalAlignment="Center" Opacity="0.6" Visibility="Collapsed" />
    </Grid>
</Page>

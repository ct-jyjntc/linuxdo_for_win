<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="LinuxDo.Features.Notifications.NotificationsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Padding="20,12" RowSpacing="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <Grid>
            <TextBlock Style="{StaticResource SubtitleTextBlockStyle}" Text="通知" />
            <Button HorizontalAlignment="Right" Content="全部已读" Click="MarkRead_Click" />
        </Grid>
        <Grid Grid.Row="1">
            <ProgressRing x:Name="LoadingRing" Width="40" Height="40" HorizontalAlignment="Center" VerticalAlignment="Center" IsActive="False" Visibility="Collapsed" />
            <ListView x:Name="NotifList" IsItemClickEnabled="True" ItemClick="NotifList_ItemClick">
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Padding="12,10" Spacing="4">
                            <TextBlock FontWeight="SemiBold" Text="{Binding Title}" TextWrapping="Wrap" />
                            <TextBlock FontSize="12" Opacity="0.65" Text="{Binding Subtitle}" />
                        </StackPanel>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
            <TextBlock x:Name="EmptyText" HorizontalAlignment="Center" VerticalAlignment="Center" Opacity="0.6" Text="暂无通知" Visibility="Collapsed" />
        </Grid>
    </Grid>
</Page>
